# Container Management Configuration
# Copy this file to .env and customize for your environment

# Slack webhook URL for notifications
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"

# List of containers to monitor (comma-separated)
CONTAINER_LIST="webapp,db,cache"

# Resource thresholds for alerts (percentage)
CPU_THRESHOLD=80
MEMORY_THRESHOLD=85

# Data directories
CONTAINER_DATA_DIR="./containers"
BACKUP_DIR="./backups"

# Log file path
LOG_FILE="./container-manager.log"

# Health check settings
HEALTH_CHECK_INTERVAL=30
MAX_RESTART_ATTEMPTS=3

# Notification settings
NOTIFY_ON_ERROR=true
NOTIFY_ON_RESTART=true
